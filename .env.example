# Copy this file to ".env" and fill in your key. The real .env is git-ignored.

# Your Anthropic (Claude) API key — required for the LIVE policy-to-rule step.
# Without it, the app still runs using the saved fallback rules.
ANTHROPIC_API_KEY=sk-ant-...

# Which model to use. Swappable so the provider/model is a one-line change.
# Default is Claude Opus 4.8. For a cheaper/faster demo you could use
# claude-haiku-4-5 or claude-sonnet-5.
LLM_MODEL=claude-opus-4-8
